---
interface Props {
  title?: string;
}

const { title = "Nota" } = Astro.props;
---

<aside
  class="not-prose my-6 rounded border border-(--color-border) bg-(--color-panel) p-4"
>
  <p
    class="font-sans text-xs font-semibold uppercase tracking-[0.14em] text-(--color-muted)"
  >
    {title}
  </p>
  <div class="mt-2 font-serif text-sm text-(--color-text)">
    <slot />
  </div>
</aside>
