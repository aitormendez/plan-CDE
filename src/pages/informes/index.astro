---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const entries = (await getCollection("reports")).sort(
  (first, second) => first.data.order - second.data.order
);
---

<BaseLayout
  title="Informes | Plan de trabajo CDE"
  description="Listado de informes del plan de trabajo CDE."
>
  <section class="mx-auto max-w-4xl">
    <h1 class="text-3xl font-semibold tracking-tight md:text-4xl">Informes</h1>
    <p class="mt-3 text-sm text-(--color-muted) md:text-base">
      Documentos de trabajo para definir el plan de comunicación y la extensión
      de configuración del proyecto.
    </p>

    <ul class="mt-8 grid gap-3">
      {
        entries.map((entry) => (
          <li>
            <a
              href={`/informes/${entry.slug}`}
              class="block rounded border border-(--color-border) bg-(--color-surface) px-5 py-4 transition hover:border-(--color-accent)"
            >
              <p class="text-lg font-medium">{entry.data.title}</p>
              {entry.data.summary && (
                <p class="mt-2 text-sm text-(--color-muted)">
                  {entry.data.summary}
                </p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
